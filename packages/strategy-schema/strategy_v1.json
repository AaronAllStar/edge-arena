{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EdgeArena Strategy v1",
  "type": "object",
  "required": ["version", "name", "asset", "timeframe", "entry_rules", "exit_rules", "risk_management"],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "asset": {
      "type": "string",
      "pattern": "^[A-Z]+/[A-Z]+$"
    },
    "timeframe": {
      "type": "string",
      "enum": ["1m", "5m", "15m", "30m", "1h", "4h", "1d", "1w"]
    },
    "entry_rules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/condition" }
    },
    "exit_rules": {
      "type": "array",
      "items": { "$ref": "#/$defs/condition" }
    },
    "risk_management": {
      "type": "object",
      "required": ["stop_loss_pct", "take_profit_pct", "position_size_pct", "max_open_positions"],
      "properties": {
        "stop_loss_pct": { "type": "number", "minimum": 0, "maximum": 100 },
        "take_profit_pct": { "type": "number", "minimum": 0, "maximum": 100 },
        "position_size_pct": { "type": "number", "exclusiveMinimum": 0, "maximum": 100 },
        "max_open_positions": { "type": "integer", "minimum": 1, "maximum": 50 }
      }
    }
  },
  "$defs": {
    "condition": {
      "type": "object",
      "required": ["type", "indicator", "operator", "target"],
      "properties": {
        "type": { "const": "condition" },
        "indicator": {
          "type": "string",
          "enum": ["EMA", "SMA", "RMA", "RSI", "MACD", "Bollinger", "ATR", "VWAP", "Stochastic", "ADX", "CCI", "MFI", "OBV", "Volume"]
        },
        "params": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        },
        "operator": {
          "type": "string",
          "enum": [">", "<", ">=", "<=", "==", "crosses_above", "crosses_below", "between", "not_between"]
        },
        "target": {
          "type": "object",
          "oneOf": [
            { "required": ["value"], "properties": { "value": { "type": "number" } } },
            { "required": ["indicator"], "properties": { "indicator": { "type": "string" }, "params": { "type": "object" } } }
          ]
        }
      }
    }
  }
}
